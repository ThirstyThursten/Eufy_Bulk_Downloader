# Eufy Security account credentials
EUFY_EMAIL=your-email@example.com
EUFY_PASSWORD=your-password

# Country code (ISO 3166-1 Alpha-2, e.g. US, DE, NL, GB)
EUFY_COUNTRY=US

# Directory where downloaded clips are saved (absolute or relative to backend/)
DOWNLOAD_DIR=./downloads

# Server port
PORT=3001

# Max concurrent downloads per job (1-5 recommended)
MAX_CONCURRENT_DOWNLOADS=2

# P2P connection preference: 0 = prefer local, 1 = prefer cloud, 2 = local only
P2P_CONNECTION_SETUP=0
